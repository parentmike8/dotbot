{
  "name": "@dotbot/server",
  "private": true,
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.883.0",
    "@dotbot/game": "workspace:*",
    "@dotbot/protocol": "workspace:*",
    "@fastify/static": "^9.3.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.2",
    "postgres": "^3.4.9",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc --noEmit",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\" --outfile=dist/index.js",
    "jitterprobe": "tsx src/playtest/jitterprobe.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}
