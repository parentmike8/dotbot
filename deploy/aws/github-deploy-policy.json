{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublishGameLiftBuilds",
      "Effect": "Allow",
      "Action": [
        "gamelift:CreateBuild",
        "gamelift:DescribeBuild",
        "gamelift:ListBuilds",
        "gamelift:RequestUploadCredentials",
        "gamelift:TagResource"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ControlPlaneStack",
      "Effect": "Allow",
      "Action": [
        "cloudformation:CreateChangeSet",
        "cloudformation:CreateStack",
        "cloudformation:DeleteChangeSet",
        "cloudformation:DescribeChangeSet",
        "cloudformation:DescribeStackEvents",
        "cloudformation:DescribeStacks",
        "cloudformation:ExecuteChangeSet",
        "cloudformation:GetTemplateSummary",
        "cloudformation:ListStackResources"
      ],
      "Resource": "arn:aws:cloudformation:us-east-1:380314682423:stack/dotbot-production-control-plane/*"
    },
    {
      "Sid": "DeploymentArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:GetBucketLocation",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:ListBucketMultipartUploads",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::dotbot-deploy-artifacts-380314682423-us-east-1",
        "arn:aws:s3:::dotbot-deploy-artifacts-380314682423-us-east-1/*"
      ]
    },
    {
      "Sid": "PassCloudFormationRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::380314682423:role/DotBotCloudFormationExecutionRole",
      "Condition": { "StringEquals": { "iam:PassedToService": "cloudformation.amazonaws.com" } }
    }
  ]
}
